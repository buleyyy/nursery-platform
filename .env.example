# ──────────────────────────────────────────────────────────────────────────────
# H. Ali Nursery — Environment Variables
# Salin file ini ke .env untuk lokal, atau set di Railway Variables panel
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (lokal) ───────────────────────────────────────────────────────────
# Untuk Railway: TIDAK perlu set ini manual.
# Railway MySQL plugin otomatis inject: MYSQLHOST, MYSQLUSER, MYSQLPASSWORD,
# MYSQLDATABASE, MYSQLPORT — app sudah support keduanya.
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=nursery_db
DB_PORT=3306

# ── Server ─────────────────────────────────────────────────────────────────────
# Railway auto-set PORT. Jangan override di Railway.
PORT=3006
NODE_ENV=production

# ── Admin Credentials ─────────────────────────────────────────────────────────
# WAJIB set di Railway Variables panel!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti_password_aman_ini
ADMIN_SECRET=ganti_secret_panjang_random_ini

# ── Frontend ───────────────────────────────────────────────────────────────────
# URL frontend Vercel — untuk CORS whitelist
# Contoh: https://nursery-platform.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app
